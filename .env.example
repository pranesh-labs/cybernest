# CyberNest Environment Configuration Example
# Copy this file to .env.development, .env.production, or .env.test and adjust values

# Application Environment
ENVIRONMENT=development
LOG_LEVEL=info

# Backend Database Config
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_password_123
POSTGRES_DB=cybernest
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres_secure_password_123@db:5432/cybernest

# Security & JWT Tokens
JWT_SECRET_KEY=generate_a_secure_random_hex_key_here_for_signatures
ACCESS_TOKEN_EXPIRE_MINUTES=60
AGENT_AUTH_TOKEN=secure_token_shared_between_agent_and_api_for_auth

# Web Port Configuration (for development proxy / frontend builds)
VITE_API_URL=http://localhost/api/v1
PORT=3000
